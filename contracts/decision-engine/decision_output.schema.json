{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digiwiz.local/contracts/decision-engine/decision_output.schema.json",
  "title": "Decision Engine Output",
  "description": "ADR-0014 — Quellenbedarf, Gates und Orchestration Plan. Keine Antworten. provider_call_allowed ist bis Context Assembly immer false.",
  "type": "object",
  "required": [
    "decision_id",
    "task",
    "query",
    "provider_call_allowed",
    "source_requirements",
    "decisions",
    "orchestration_plan",
    "required_fields",
    "governance",
    "readiness",
    "decision_confidence",
    "decision_trace_id",
    "policy_refs"
  ],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "task": { "type": "string" },
    "query": { "type": "string" },
    "provider_call_allowed": {
      "const": false,
      "description": "Provider-Aufruf erst nach erfolgreicher Context Assembly erlaubt (ADR-0011)"
    },
    "source_requirements": { "$ref": "decision_shared.schema.json#/$defs/source_requirements" },
    "decisions": {
      "type": "object",
      "required": [
        "sql_required",
        "sql_not_required",
        "kp_governance_required",
        "knowledge_graph_required",
        "chroma_required",
        "web_required",
        "downstream_answer_possible",
        "clarification_required",
        "approval_required",
        "block_execution"
      ],
      "properties": {
        "sql_required": { "type": "boolean" },
        "sql_not_required": { "type": "boolean" },
        "kp_governance_required": { "const": true },
        "knowledge_graph_required": { "type": "boolean" },
        "chroma_required": { "type": "boolean" },
        "web_required": { "type": "boolean" },
        "downstream_answer_possible": {
          "type": "boolean",
          "description": "Antwort theoretisch möglich, wenn Downstream erfolgreich — kein Provider-Freigabe-Signal"
        },
        "clarification_required": { "type": "boolean" },
        "approval_required": { "type": "boolean" },
        "block_execution": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "orchestration_plan": {
      "type": "array",
      "items": { "$ref": "decision_shared.schema.json#/$defs/orchestration_step" },
      "minItems": 1
    },
    "required_fields": { "$ref": "decision_shared.schema.json#/$defs/required_fields" },
    "governance": { "$ref": "decision_shared.schema.json#/$defs/governance_summary" },
    "readiness": {
      "type": "object",
      "required": ["ready_for_source_resolution", "next_stage", "answer_generation_allowed_after_context_assembly"],
      "properties": {
        "ready_for_source_resolution": { "type": "boolean" },
        "answer_generation_allowed_after_context_assembly": {
          "type": "boolean",
          "description": "Erst nach Context Assembly und ready_for_generation auf true setzbar"
        },
        "next_stage": { "$ref": "decision_shared.schema.json#/$defs/next_stage" }
      },
      "additionalProperties": false
    },
    "decision_confidence": { "$ref": "#/$defs/decision_confidence" },
    "decision_trace_id": { "type": "string", "minLength": 1 },
    "policy_refs": {
      "type": "object",
      "required": ["decision_policy_ref", "resolution_policy_ref"],
      "properties": {
        "decision_policy_ref": {
          "type": "string",
          "const": "contracts/decision-engine/decision_policy.yaml"
        },
        "resolution_policy_ref": {
          "type": "string",
          "const": "contracts/source-resolution/source_resolution_policy.yaml"
        },
        "routing_ref": { "type": "string" },
        "playbook_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "decision_confidence": {
      "type": "object",
      "required": ["overall", "sources"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 1 },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_id", "decision", "confidence", "reason_code"],
            "properties": {
              "source_id": { "type": "string" },
              "decision": { "enum": ["required", "optional", "skipped"] },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "reason_code": { "$ref": "decision_shared.schema.json#/$defs/reason_code" },
              "evidence_refs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "rejected_alternatives": {
                "type": "array",
                "items": { "$ref": "decision_shared.schema.json#/$defs/rejected_alternative" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "decisions": { "properties": { "sql_required": { "const": true } } } }
      },
      "then": {
        "properties": {
          "decisions": { "properties": { "sql_not_required": { "const": false } } },
          "source_requirements": {
            "properties": {
              "sql_crm_stammdaten": {
                "properties": { "status": { "const": "required" } }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "decisions": { "properties": { "sql_not_required": { "const": true } } } }
      },
      "then": {
        "properties": {
          "decisions": { "properties": { "sql_required": { "const": false } } }
        }
      }
    },
    {
      "if": {
        "properties": { "decisions": { "properties": { "block_execution": { "const": true } } } }
      },
      "then": {
        "properties": {
          "readiness": {
            "properties": { "next_stage": { "const": "block" } }
          },
          "provider_call_allowed": { "const": false }
        }
      }
    }
  ],
  "not": {
    "required": ["published_url", "auto_publish", "answer_text"]
  }
}
