{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digiwiz.local/contracts/decision-engine/decision_trace.schema.json",
  "title": "Decision Engine Trace",
  "description": "ADR-0014 — Maschinenlesbares Audit-Log pro Entscheidungsschritt.",
  "type": "object",
  "required": ["trace_id", "decision_id", "engine_version", "entries"],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "decision_id": { "type": "string", "minLength": 1 },
    "engine_version": { "type": "string" },
    "task": { "type": "string" },
    "query": { "type": "string" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/trace_entry" },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "trace_entry": {
      "type": "object",
      "required": [
        "step_id",
        "timestamp",
        "rule_ref",
        "rule_type",
        "outcome",
        "rationale"
      ],
      "properties": {
        "step_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "rule_ref": { "type": "string", "minLength": 1 },
        "rule_type": {
          "enum": ["contract", "playbook", "adr", "routing", "intent_signal"]
        },
        "input_signals": { "type": "object" },
        "outcome": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "source_effect": {
          "type": "object",
          "additionalProperties": {
            "enum": ["required", "optional", "skipped"]
          }
        }
      },
      "additionalProperties": false
    }
  }
}
