{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digiwiz.local/contracts/decision-engine/decision_context.schema.json",
  "title": "Decision Context",
  "description": "ADR-0014 — Weitergabe an Source Resolution, Context Assembly und DAR Context Builder.",
  "type": "object",
  "required": [
    "decision_id",
    "task",
    "query",
    "sql_first",
    "source_requirements",
    "orchestration_plan",
    "required_fields",
    "governance",
    "policy_refs",
    "next_stage"
  ],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "decision_trace_id": { "type": "string" },
    "task": { "type": "string" },
    "query": { "type": "string" },
    "sql_first": { "type": "boolean" },
    "source_requirements": { "$ref": "decision_shared.schema.json#/$defs/source_requirements" },
    "orchestration_plan": {
      "type": "array",
      "items": { "$ref": "decision_shared.schema.json#/$defs/orchestration_step" },
      "minItems": 1
    },
    "required_fields": { "$ref": "decision_shared.schema.json#/$defs/required_fields" },
    "governance": { "$ref": "decision_shared.schema.json#/$defs/governance_summary" },
    "policy_refs": {
      "type": "object",
      "required": ["decision_policy_ref", "resolution_policy_ref", "decision_output_ref"],
      "properties": {
        "decision_policy_ref": {
          "type": "string",
          "const": "contracts/decision-engine/decision_policy.yaml"
        },
        "resolution_policy_ref": {
          "type": "string",
          "const": "contracts/source-resolution/source_resolution_policy.yaml"
        },
        "decision_output_ref": {
          "type": "string",
          "description": "decision_id oder Pfad zum Decision-Output für Audit-Kette"
        },
        "decision_trace_ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "next_stage": { "$ref": "decision_shared.schema.json#/$defs/next_stage" },
    "readiness": {
      "type": "object",
      "properties": {
        "ready_for_source_resolution": { "type": "boolean" },
        "answer_generation_allowed_after_context_assembly": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
