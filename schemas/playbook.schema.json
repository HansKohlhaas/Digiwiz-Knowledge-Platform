{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digiwiz.local/schemas/playbook.schema.json",
  "title": "Digiwiz Playbook YAML (Contract)",
  "description": "Governance-Metadaten für alle Playbooks — maschinell prüfbar.",
  "type": "object",
  "required": ["name", "title", "version", "governance"],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "title": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "governance": {
      "type": "object",
      "required": ["owner", "approval_required", "auto_publish", "version"],
      "properties": {
        "owner": { "type": "string" },
        "approval_required": { "const": true },
        "auto_publish": { "const": false },
        "version": { "type": "string" },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quality_checks": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "decision_hints": {
      "type": "object",
      "description": "ADR-0014 — optionale Hinweise für Decision Engine (keine Fachlogik im Code)",
      "properties": {
        "default_query_type": { "type": "string" },
        "sql_first_when_entities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preferred_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_field_templates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field_id", "mandatory"],
            "properties": {
              "field_id": { "type": "string" },
              "mandatory": { "type": "boolean" },
              "preferred_sources": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "clarification_triggers": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
